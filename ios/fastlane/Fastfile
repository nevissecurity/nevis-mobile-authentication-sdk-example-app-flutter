##
## Fastlane configuration for the Nevis Mobile Authentication SDK Example App Flutter iOS application.
## See https://docs.fastlane.tools
##

require "securerandom"

default_platform(:ios)

project = "Runner.xcodeproj"
app_identifier = "ch.nevis.mobile.authentication.sdk.flutter.example"
display_name = "Nevis Mobile Authentication SDK Example App Flutter iOS"
keychain_password = SecureRandom.base64
ENV["FASTLANE_XCODEBUILD_SETTINGS_TIMEOUT"] = "120"
ENV["PERMISSION_CAMERA"] = "1"

##
# Ensures a temporary macOS keychain exists for the current build.
#
# This is a convenience wrapper that first removes any existing keychain with the same
# name (if present) and then re-creates it using {#create_temp_keychain}.
#
# @param name [String] Keychain name (without the "-db" suffix).
# @param password [String] Password used to create/unlock the keychain.
# @return [void]
def ensure_temp_keychain(name, password)
	delete_temp_keychain(name)
	create_temp_keychain(name, password)
end

##
# Creates and unlocks a temporary macOS keychain for code signing.
#
# @param name [String] Keychain name (without the "-db" suffix).
# @param password [String] Password used to create/unlock the keychain.
# @return [void]
#
# @raise [FastlaneCore::Interface::FastlaneError] If the underlying fastlane action fails.
def create_temp_keychain(name, password)
	create_keychain(
		name:,
		password:,
		unlock: true,
		timeout: 0,
		lock_when_sleeps: true
	)
end

##
# Deletes the temporary macOS keychain if it exists.
#
# Checks for the keychain database file at:
#   ~/Library/Keychains/<name>-db
#
# @param name [String] Keychain name (without the "-db" suffix).
# @return [void]
#
# @raise [FastlaneCore::Interface::FastlaneError] If deletion fails after existence check passes.
def delete_temp_keychain(name)
	delete_keychain(name:) if File.exist? File.expand_path("~/Library/Keychains/#{name}-db")
end

##
# Reports a successful build to Slack (if `SLACK_WEBHOOK_URL` environment variable is set).
#
# Uses `CURRENT_BUILD_URL` environment variable to provide context on success.
#
# @param message [String] Message prefix to send.
# @return [void]
def report_on_success(message)
	slack(
		message: "#{message}\nCheck build logs: #{ENV['CURRENT_BUILD_URL']}",
		slack_url: ENV["SLACK_WEBHOOK_URL"]
	) if ENV["SLACK_WEBHOOK_URL"]
end

##
# Reports a failed build to Slack (if `SLACK_WEBHOOK_URL` environment variable is set)
# and fails the lane with the given exception and surface the error in Fastlane output.
#
# Uses `CURRENT_BUILD_URL` and `BUILD_NUMBER` environment variables to provide context on the failure.
#
# @param message [String] Message to send.
# @param exception [Exception] The exception to report.
# @return [void]
def report_on_error(message, exception)
	slack(
		message: "#{message}\nCheck build logs: #{ENV['CURRENT_BUILD_URL']}",
		slack_url: ENV["SLACK_WEBHOOK_URL"],
		success: false,
		attachment_properties: {
			fields: [
				{
					title: "Error message",
					value: exception.to_s,
					short: false
				}
			]
		}
	) if ENV["SLACK_WEBHOOK_URL"]
	UI.user_error!(exception.to_s)
end

platform :ios do
	desc "Pull request build"
	desc ""
	lane :pr do
		utilize_private_repos
		setup
		build(clean: true)
	end

	desc "Continuous build"
	desc "#### Options"
	desc " * **`version`**: The version of the application."
	desc " * **`build_number`**: The build number of the application."
	desc ""
	lane :develop do |options|
		utilize_private_repos
		setup
		build
		distribute(options)
	end

	desc "Release build"
	desc "#### Options"
	desc " * **`version`**: The version of the application."
	desc " * **`build_number`**: The build number of the application."
	desc ""
	lane :main do |options|
		setup
		build
		distribute(options)
	end

	####
	#### Private lanes
	####

	desc "Utilize private repositories"
	desc ""
	private_lane :utilize_private_repos do
		update_nma_sdk(
			project:,
			repository_url: ENV["PRIVATE_NATIVE_REPOSITORY_URL"],
			version: ENV["NMA_IOS_SDK_VERSION"]
		)
	end

	desc "Build the application"
	desc "#### Options"
	desc " * **`clean`**: Flag that tells whether the lane should perform a clean."
	desc ""
	private_lane :build do |options|
		clean = options[:clean] || false

		UI.message("Archive Preparation")
		Dir.chdir("..") do
			# Mandatory to get a FlutterGeneratedPluginSwiftPackage with a correct iOS minimum version
			Actions.sh("flutter build ios --config-only --no-codesign", error_callback: lambda { |result|
				raise "❌ Archive Preparation failed! Result: #{result}"
			})
			Actions.sh("flutter build ios --no-codesign", error_callback: lambda { |result|
				raise "❌ Archive Preparation failed! Result: #{result}"
			})
		end

		delete_temp_keychain(ENV["TEMP_KEYCHAIN_NAME"]) if clean
	end

	desc "Distribute the application"
	desc "#### Options"
	desc " * **`version`**: The version of the application."
	desc " * **`build_number`**: The build number of the application."
	desc ""
	private_lane :distribute do |options|
		version = options[:version]
		build_number = options[:build_number]
		keychain_name = ENV["TEMP_KEYCHAIN_NAME"]

		UI.message("Distributing #{display_name} #{version} (#{build_number}) 📦")

		gym(
			workspace: "Runner.xcworkspace",
			scheme: "Runner",
			configuration: "Release",
			clean: true,
			skip_profile_detection: true,
			export_method: "ad-hoc",
			export_options: {
				provisioningProfiles: {
					app_identifier => ENV["PROVISIONING_PROFILE_SPECIFIER"]
				}
			},
			xcargs: "OTHER_CODE_SIGN_FLAGS=\"--keychain=#{keychain_name}\""
		)

		firebase_app_distribution(
			app: ENV["FIREBASE_APP_ID_IOS"],
			ipa_path: "./Runner.ipa",
			groups: "developers, internal-testers, presales"
		) if ENV["FIREBASE_TOKEN"]

		delete_temp_keychain(keychain_name)
		report_on_success("#{display_name} build is completed: #{version} (#{build_number}) ✅")
	rescue => e
		delete_temp_keychain(keychain_name)
		report_on_error("#{display_name} build failed ❌", e)
	end

	desc "Sets up code signing"
	desc ""
	private_lane :setup do
		keychain_name = ENV["TEMP_KEYCHAIN_NAME"]
		ensure_temp_keychain(
			keychain_name,
			keychain_password
		)

		match(
			type: "adhoc",
			readonly: true,
			app_identifier:,
			git_url: ENV["MATCH_GIT_URL"],
			git_branch: "main",
			keychain_name:,
			keychain_password:
		)

		profile_name = ENV["sigh_#{app_identifier}_adhoc_profile-name"]
		update_code_signing_settings(
			path: project,
			build_configurations: ["Release"],
			use_automatic_signing: false,
			team_id: ENV["DEVELOPER_PORTAL_TEAM_ID"],
			code_sign_identity: ENV["CODE_SIGNING_IDENTITY"],
			profile_name:
		)
	end
end
